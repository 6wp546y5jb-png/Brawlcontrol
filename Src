    MinimizeBtn.TextColor3 = Color3.fromRGB(150, 160, 155); MinimizeBtn.TextSize = 20; MinimizeBtn.Font = Enum.Font.GothamMedium

    -- [[ SQUIRCLE FLOATING ACTION BUTTON (Top-Right Interface) ]]
    local FloatingActionButton = Instance.new("TextButton", ScreenGui)
    FloatingActionButton.Size = UDim2.new(0, 50, 0, 50) -- Adjusted to exact 50x50 dimensions
    FloatingActionButton.Position = UDim2.new(1, -72, 0, 45) 
    FloatingActionButton.BackgroundColor3 = CardBgColor
    FloatingActionButton.Text = "F"
    FloatingActionButton.TextColor3 = TextGreen
    FloatingActionButton.Font = Enum.Font.GothamBold
    FloatingActionButton.TextSize = 20
    FloatingActionButton.Visible = false
    Instance.new("UICorner", FloatingActionButton).CornerRadius = UDim.new(0, 12) 
    
    local FloatStroke = Instance.new("UIStroke", FloatingActionButton)
    FloatStroke.Thickness = 1.5
    FloatStroke.Color = BorderColor

    MinimizeBtn.MouseButton1Click:Connect(function() Main.Visible = false; FloatingActionButton.Visible = true end)
    FloatingActionButton.MouseButton1Click:Connect(function() FloatingActionButton.Visible = false; Main.Visible = true end)
end

